{
  "name": "private-journal-cli",
  "version": "1.0.0",
  "description": "Local-first CLI for private journaling, structured thoughts, and semantic search for AI agents and assistants",
  "main": "dist/index.js",
  "bin": {
    "private-journal": "./dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "private-journal",
    "journal",
    "cli",
    "assistant",
    "ai-agents",
    "semantic-search",
    "local-first",
    "markdown"
  ],
  "author": "Jesse Vincent <jesse@fsck.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/urbansheep/private-journal-cli.git"
  },
  "homepage": "https://github.com/urbansheep/private-journal-cli#readme",
  "bugs": {
    "url": "https://github.com/urbansheep/private-journal-cli/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ]
}
